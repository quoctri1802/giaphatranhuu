// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Person {
  id            String   @id @default(cuid())
  fullName      String
  otherName     String?
  gender        String   // MALE, FEMALE
  birthDate     DateTime?
  deathDate     DateTime? // Ngày giỗ Dương lịch
  deathDateLunar String?   // Ngày giỗ Âm lịch (ví dụ: 12/03)
  bio           String?  @db.Text
  avatarUrl     String?
  generation    Int
  branch        String?  
  posX          Float?   // Vị trí trên cây
  posY          Float?
  lat           Float?   // Tọa độ bản đồ (mộ phần)
  lng           Float?
  
  // Quan hệ
  parents       Person[] @relation("ParentChild")
  children      Person[] @relation("ParentChild")
  spouses       Person[] @relation("SpouseRelation")
  spouseOf      Person[] @relation("SpouseRelation")

  memories      Memory[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  password      String
  name          String?
  role          String   @default("VIEWER") // ADMIN, EDITOR, VIEWER
  avatarUrl     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Post {
  id            String   @id @default(cuid())
  title         String
  content       String   @db.Text
  excerpt       String?
  coverImage    String?
  authorId      String
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Content {
  id            String   @id @default(cuid())
  page          String   @unique // home, history
  data          Json     // Lưu cấu trúc JSON cho các đoạn văn bản, hình ảnh
  updatedAt     DateTime @updatedAt
}

model Media {
  id          String   @id @default(cuid())
  title       String
  url         String
  type        String   // IMAGE, VIDEO, DOCUMENT
  category    String?  // GIO_TOC, KHANH_THANH, TU_LIEU_CO
  createdAt   DateTime @default(now())
}

model Memory {
  id          String   @id @default(cuid())
  content     String   @db.Text
  authorName  String
  personId    String
  person      Person   @relation(fields: [personId], references: [id])
  createdAt   DateTime @default(now())
}

model Registration {
  id          String   @id @default(cuid())
  fullName    String
  email       String
  phone       String?
  message     String   @db.Text
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime @default(now())
}
